{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentiment-analyst.local/schemas/document-score.schema.json",
  "title": "DocumentScore",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "score_id",
    "doc_id",
    "model_version",
    "event_family",
    "event_type",
    "event_direction",
    "bullish_bearish_label",
    "urgency",
    "tradeability",
    "horizon",
    "sentiment_score",
    "impact_score",
    "relevance_score",
    "novelty_score",
    "timeliness_score",
    "source_reliability_score",
    "extraction_quality_score",
    "llm_confidence",
    "rule_confidence",
    "classification_confidence",
    "final_confidence",
    "document_alpha",
    "reason_codes",
    "evidence_quotes",
    "explanation_short",
    "scored_at"
  ],
  "properties": {
    "score_id": { "type": "string", "format": "uuid" },
    "doc_id": { "type": "string", "format": "uuid" },
    "model_version": { "type": "string" },
    "event_family": { "type": "string" },
    "event_type": { "type": "string" },
    "event_direction": {
      "type": "string",
      "enum": ["positive", "negative", "mixed", "unclear"]
    },
    "bullish_bearish_label": {
      "type": "string",
      "enum": ["bullish", "neutral", "bearish"]
    },
    "urgency": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "tradeability": {
      "type": "string",
      "enum": ["ignore", "monitor", "actionable"]
    },
    "horizon": { "type": "string" },
    "sentiment_score": { "type": "number", "minimum": -1, "maximum": 1 },
    "impact_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "relevance_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "novelty_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "timeliness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_reliability_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "extraction_quality_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "llm_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "rule_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "classification_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "final_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "document_alpha": { "type": "number", "minimum": -1, "maximum": 1 },
    "reason_codes": { "type": "array", "items": { "type": "string" } },
    "evidence_quotes": { "type": "array", "items": { "type": "string" } },
    "explanation_short": { "type": "string", "maxLength": 220 },
    "score_metadata": { "type": "object" },
    "scored_at": { "type": "string", "format": "date-time" }
  }
}
