{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentiment-analyst.local/schemas/normalized-document.schema.json",
  "title": "NormalizedDocument",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "doc_id",
    "raw_id",
    "headline",
    "published_at",
    "source_name",
    "source_type",
    "source_trust",
    "is_official_filing",
    "is_press_release",
    "mentioned_tickers",
    "companies",
    "regions",
    "themes",
    "novelty_score",
    "timeliness_score",
    "extraction_quality_score",
    "mapping_confidence",
    "processing_notes"
  ],
  "properties": {
    "doc_id": { "type": "string", "format": "uuid" },
    "raw_id": { "type": "string", "format": "uuid" },
    "canonical_url": { "type": ["string", "null"], "format": "uri" },
    "headline": { "type": "string", "minLength": 1 },
    "summary_text": { "type": ["string", "null"] },
    "body_text": { "type": ["string", "null"] },
    "published_at": { "type": "string", "format": "date-time" },
    "source_name": { "type": "string" },
    "source_type": {
      "type": "string",
      "enum": ["rss", "news_api", "filing", "insider", "macro", "calendar", "manual"]
    },
    "source_trust": { "type": "number", "minimum": 0, "maximum": 1 },
    "is_official_filing": { "type": "boolean" },
    "is_press_release": { "type": "boolean" },
    "primary_ticker": { "type": ["string", "null"] },
    "mentioned_tickers": { "type": "array", "items": { "type": "string" } },
    "companies": { "type": "array", "items": { "type": "string" } },
    "sector": { "type": ["string", "null"] },
    "industry": { "type": ["string", "null"] },
    "regions": { "type": "array", "items": { "type": "string" } },
    "themes": { "type": "array", "items": { "type": "string" } },
    "dedupe_cluster_id": { "type": ["string", "null"], "format": "uuid" },
    "novelty_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "timeliness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "extraction_quality_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "mapping_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "processing_notes": { "type": "object" }
  }
}
