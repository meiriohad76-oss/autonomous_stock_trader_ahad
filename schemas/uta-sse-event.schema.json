{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UTA SSE Event",
  "type": "object",
  "required": ["type", "timestamp"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["uta_signal_result", "uta_scan_progress", "uta_lane_state", "uta_revalidation"]
    },
    "timestamp": { "type": "string" },
    "payload": { "type": "object" }
  }
}

