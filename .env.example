PORT=3000
HOST=127.0.0.1
PI_PERFORMANCE_MODE=false
DATABASE_ENABLED=true
DATABASE_PROVIDER=sqlite
DATABASE_PATH=data/sentiment-analyst.sqlite
DATABASE_URL=
DATABASE_AUTOSAVE_MS=15000
LIGHTWEIGHT_STATE_ENABLED=false
LIGHTWEIGHT_STATE_PATH=data/runtime-state.json
LIGHTWEIGHT_STATE_MAX_DOCUMENTS=500
SQLITE_BACKUP_ENABLED=true
SQLITE_BACKUP_DIR=data/backups
SQLITE_BACKUP_INTERVAL_MS=21600000
SQLITE_BACKUP_RETENTION_COUNT=28
SQLITE_BACKUP_RETENTION_DAYS=14
SQLITE_BACKUP_ON_STARTUP=true
UNIVERSE_NAME=US Mega Cap Watchlist
DEFAULT_WINDOW=1h
ALERT_CONFIDENCE_THRESHOLD=0.85
TWELVE_DATA_API_KEY=your_twelve_data_key_here
MARKET_DATA_PROVIDER=twelvedata
MARKET_FLOW_ENABLED=true
AUTO_START_MARKET_FLOW=true
LIVE_NEWS_ENABLED=true
LIVE_NEWS_REQUEST_RETRIES=1
SEC_USER_AGENT=SentimentAnalyst/1.0 contact=you@example.com
SEC_FORM4_ENABLED=true
SEC_13F_ENABLED=true
AUTO_START_SEC_13F=true
AUTO_START_SEC_FUNDAMENTALS=true
FUNDAMENTAL_SEC_MAX_COMPANIES_PER_POLL=24
AUTO_START_FUNDAMENTAL_MARKET_DATA=true
SEC_REQUEST_RETRIES=1

# Broker / execution integration.
# Defaults are intentionally preview-only and paper-trading oriented.
BROKER_PROVIDER=alpaca
BROKER_TRADING_MODE=paper
BROKER_SUBMIT_ENABLED=false
BROKER_REQUEST_TIMEOUT_MS=12000
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_ALLOW_LIVE_TRADING=false
EXECUTION_MIN_CONVICTION=0.62
EXECUTION_MIN_NOTIONAL_USD=25
EXECUTION_MAX_ORDER_NOTIONAL_USD=1000
EXECUTION_MAX_POSITION_PCT=0.03
EXECUTION_DEFAULT_EQUITY_USD=100000
EXECUTION_ALLOW_SHORTS=false
EXECUTION_USE_BRACKET_ORDERS=true
EXECUTION_DEFAULT_ORDER_TYPE=market
EXECUTION_DEFAULT_TIME_IN_FORCE=day
RISK_MAX_GROSS_EXPOSURE_PCT=0.35
RISK_MAX_SINGLE_NAME_EXPOSURE_PCT=0.08
RISK_MAX_OPEN_ORDERS=10
RISK_BLOCK_WHEN_RUNTIME_CONSTRAINED=false
